# Copy this file to .env before running locally
HORDEFORGE_GATEWAY_URL=http://localhost:8000
HORDEFORGE_PIPELINES_DIR=pipelines
HORDEFORGE_RULES_DIR=rules
HORDEFORGE_RULE_SET_VERSION=1.0
HORDEFORGE_REQUEST_TIMEOUT_SECONDS=30
HORDEFORGE_STATUS_TIMEOUT_SECONDS=15
HORDEFORGE_HEALTH_TIMEOUT_SECONDS=10
HORDEFORGE_MAX_PARALLEL_WORKERS=4
HORDEFORGE_STRICT_SCHEMA_VALIDATION=true
HORDEFORGE_ENABLE_DYNAMIC_FALLBACK=true
HORDEFORGE_WEBHOOK_SECRET=local-dev-secret
HORDEFORGE_STORAGE_DIR=.hordeforge_data
HORDEFORGE_DATABASE_URL=postgresql+psycopg://hordeforge:hordeforge@localhost:5432/hordeforge
HORDEFORGE_IDEMPOTENCY_TTL_SECONDS=3600
HORDEFORGE_OPERATOR_API_KEY=local-operator-key
HORDEFORGE_OPERATOR_ALLOWED_ROLES=operator
HORDEFORGE_MANUAL_COMMAND_ALLOWED_SOURCES=api
HORDEFORGE_DEFAULT_TENANT_ID=default
HORDEFORGE_TENANT_REPOSITORY_MAP={"default": ["*"]}
HORDEFORGE_ENFORCE_TENANT_BOUNDARIES=false
HORDEFORGE_ALERT_SLACK_WEBHOOK=
HORDEFORGE_ALERT_SMTP_HOST=
HORDEFORGE_ALERT_SMTP_PORT=587
HORDEFORGE_ALERT_SMTP_SENDER=
HORDEFORGE_ALERT_SMTP_RECIPIENTS=
HORDEFORGE_ALERT_SMTP_USERNAME=
HORDEFORGE_ALERT_SMTP_PASSWORD=
HORDEFORGE_ALERT_SMTP_USE_TLS=true
HORDEFORGE_RETENTION_RUNS_DAYS=90
HORDEFORGE_RETENTION_LOGS_DAYS=30
HORDEFORGE_RETENTION_ARTIFACTS_DAYS=7
HORDEFORGE_RETENTION_AUDIT_DAYS=365
PYTHONUNBUFFERED=1

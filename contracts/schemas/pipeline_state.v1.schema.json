{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hordeforge.local/schemas/pipeline_state.v1.schema.json",
  "title": "Pipeline State v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "pipeline_name",
    "current_step",
    "artifacts",
    "pending_steps",
    "failed_steps",
    "locks",
    "retry_state"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "pipeline_name": {
      "type": "string",
      "minLength": 1
    },
    "current_step": {
      "type": ["string", "null"]
    },
    "artifacts": {
      "type": "object"
    },
    "pending_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failed_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "locks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "retry_state": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    }
  }
}

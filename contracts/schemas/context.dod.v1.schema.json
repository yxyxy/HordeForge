{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hordeforge.local/schemas/context.dod.v1.schema.json",
  "title": "DoD Context v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "acceptance_criteria",
    "bdd_scenarios"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "title": {
      "type": "string",
      "description": "Issue title for context"
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "bdd_scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "given",
          "when",
          "then"
        ],
        "properties": {
          "given": {
            "type": "string",
            "minLength": 1
          },
          "when": {
            "type": "string",
            "minLength": 1
          },
          "then": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "extraction_method": {
      "type": "string",
      "description": "Method used to extract DoD (llm, deterministic, deterministic_fallback)",
      "enum": ["llm", "deterministic", "deterministic_fallback"]
    }
  }
}

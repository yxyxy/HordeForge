{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hordeforge.local/schemas/agent_result.v1.schema.json",
  "title": "AgentResult v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "artifacts",
    "decisions",
    "logs",
    "next_actions"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "status": {
      "type": "string",
      "enum": [
        "SUCCESS",
        "PARTIAL_SUCCESS",
        "FAILED",
        "BLOCKED"
      ]
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "content"
        ],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string"
          },
          "content": {},
          "metadata": {
            "type": "object"
          }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "reason",
          "confidence"
        ],
        "properties": {
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "logs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "test_results": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "passed",
        "failed"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "mode": {
          "type": "string"
        }
      }
    }
  }
}

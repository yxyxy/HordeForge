{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hordeforge.local/schemas/context.spec.v1.schema.json",
  "title": "Specification Context v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "summary",
    "requirements"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
